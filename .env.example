# Supabase — copie para .env.local e preencha com os valores do seu projeto.
# Project Settings → API no painel do Supabase.
#
# A chave anon é pública por design (a RLS protege os dados).
# NUNCA coloque a chave service_role aqui nem em qualquer arquivo do frontend.

VITE_SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# hCaptcha — obtido em hcaptcha.com (plano gratuito).
# Deixe em branco para desabilitar o CAPTCHA em dev.
# Em produção, configure também a Secret Key no Supabase:
#   Authentication → Settings → Enable CAPTCHA → Provider: hCaptcha → cole a Secret Key.
# VITE_HCAPTCHA_SITE_KEY=sua-site-key-aqui
